# ============================================
# VETTRACK — Variáveis de Ambiente
# ============================================
# Copie este arquivo para .env.local e preencha

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...

# --- Prisma (PostgreSQL do Supabase) ---
# Formato: postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres:SUA_SENHA@db.SEU-PROJETO.supabase.co:5432/postgres

# --- Upstash Redis ---
UPSTASH_REDIS_REST_URL=https://SEU-REDIS.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxxxx

# --- WhatsApp Business API ---
WHATSAPP_PHONE_ID=123456789
WHATSAPP_TOKEN=EAAxxxxx
WHATSAPP_VERIFY_TOKEN=vettrack_webhook_verify
WHATSAPP_APP_SECRET=xxxxx

# --- Stripe ---
# Chave secreta — Dashboard Stripe → Developers → API keys → Secret key
STRIPE_SECRET_KEY=sk_live_...

# Webhook secret — Dashboard Stripe → Developers → Webhooks → seu endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_...

# Price IDs dos planos — Dashboard Stripe → Products → selecione o produto → copie o Price ID
STRIPE_PRICE_BASICO=price_...
STRIPE_PRICE_PROFISSIONAL=price_...
STRIPE_PRICE_PREMIUM=price_...

# Mesmos Price IDs expostos ao cliente (usados na página de planos)
NEXT_PUBLIC_STRIPE_PRICE_BASICO=price_...
NEXT_PUBLIC_STRIPE_PRICE_PROFISSIONAL=price_...
NEXT_PUBLIC_STRIPE_PRICE_PREMIUM=price_...

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
